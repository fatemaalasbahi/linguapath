# LinguaPath Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.

# --- Database (Neon PostgreSQL) ---

# Pooled connection — Next.js runtime (required on Vercel and locally)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Unpooled connection — Drizzle Kit migrations and CLI (local/CI only)
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require

# --- Authentication (Neon Auth) ---
# From Neon Console → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32-min-32-chars

# Add your production URL (e.g. linguapath-jet.vercel.app) to Neon Auth trusted domains.

# --- AI (Google Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Notifications (Slack) ---
# Server-only — never exposed to the browser. Optional; feedback saves without it.
SLACK_WEBHOOK_URL=
