# LinguaPath Environment Variables
# Copy this file to .env.local and fill in values as each phase is implemented.
# Never commit .env.local to version control.

# Phase 3 — Neon PostgreSQL (pooled — runtime Next.js client)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Phase 3 — Neon PostgreSQL (unpooled — Drizzle Kit migrations and CLI tools)
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require

# Phase 4 — Neon Auth (from Neon Console → Branch → Auth → Configuration)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32-min-32-chars

# Phase 6 — Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Phase 9 — Slack Webhook
SLACK_WEBHOOK_URL=
